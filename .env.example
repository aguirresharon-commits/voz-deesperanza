# Copiá este archivo como `.env` en la raíz del proyecto y completá los valores
# desde Firebase Console → Configuración del proyecto → Tus apps → SDK de configuración

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Opcional — subida de imágenes (Cloudinary). Si tu cuenta es EU/AP, definí el host correcto.
# VITE_CLOUDINARY_API_HOST=api.cloudinary.com
# VITE_CLOUDINARY_CLOUD_NAME=
# VITE_CLOUDINARY_UPLOAD_PRESET=
